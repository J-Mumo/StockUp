# StockUp production environment — copy to .env.production on the VM and fill in.
# Never commit the real .env.production.

# --- Postgres (used by both the postgres service and DATABASE_URL in compose) ---
POSTGRES_USER=stockup
POSTGRES_PASSWORD=CHANGE_ME_to_a_long_random_string
POSTGRES_DB=stockup

# --- App ---
APP_NAME=StockUp
APP_ENV=production
APP_DEBUG=false
APP_PORT=8000

# --- JWT (generate with: openssl rand -hex 48) ---
JWT_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_48
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Data sources ---
YFINANCE_ENABLED=true
SCRAPER_ENABLED=true
SCRAPER_BASE_URL=https://afx.kwayisi.org/ngse/
MARKETSCREENER_ENABLED=true

# --- AI enrichment (set the provider you use; leave the other blank) ---
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# AI_MODEL=

# --- Scheduled jobs (hours in EAT / UTC+3) ---
PRICE_FETCH_HOUR=18
VALUATION_CALC_HOUR=19
ALERT_EVAL_HOUR=19
ALERT_EVAL_MINUTE=30
